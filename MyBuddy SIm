import SwiftUI
import Combine

// MARK: - Models
struct GroceryItem: Identifiable {
    let id = UUID()
    var name: String
    var price: Double
}

// Payment Method Enum
enum PaymentMethod: String, CaseIterable, Identifiable {
    case visa = "Visa"
    case credit = "Credit Card"
    case ebt = "EBT"
    
    var id: String { self.rawValue }
    
    var icon: String {
        switch self {
        case .visa: return "creditcard.fill"
        case .credit: return "banknote.fill"
        case .ebt: return "leaf.fill"
        }
    }
    
    var color: Color {
        switch self {
        case .visa: return .blue
        case .credit: return .purple
        case .ebt: return .green
        }
    }
}
struct PaymentCardView: View {
    let method: PaymentMethod
    let isSelected: Bool
    
    var body: some View {
        HStack {
            Image(systemName: method.icon)
                .font(.title2)
                .foregroundColor(.white)
                .padding(10)
                .background(method.color)
                .clipShape(Circle())
            
            Text(method.rawValue)
                .foregroundColor(.white)
                .fontWeight(.semibold)
            
            Spacer()
            
            if isSelected {
                Image(systemName: "checkmark.circle.fill")
                    .foregroundColor(.green)
                    .font(.title2)
            }
        }
        .padding()
        .background(
            RoundedRectangle(cornerRadius: 12)
                .fill(isSelected ? Color.green.opacity(0.3) : Color.white.opacity(0.1))
        )
        .overlay(
            RoundedRectangle(cornerRadius: 12)
                .stroke(isSelected ? Color.green : Color.clear, lineWidth: 2)
        )
    }
}

struct Purchase: Identifiable {
    let id = UUID()
    var items: [GroceryItem]
    var total: Double
    var date: Date
    var paymentMethod: PaymentMethod
}

// MARK: - ViewModel
class BudgetViewModel: ObservableObject {
    
    @Published var budget: Double = 100.0
    @Published var spent: Double = 0.0
    @Published var groceryList: [GroceryItem] = []
    @Published var purchases: [Purchase] = []
    
    @Published var selectedPayment: PaymentMethod = .visa
    
    let defaultItems: [GroceryItem] = [
        GroceryItem(name: "Eggs", price: 2.50),
        GroceryItem(name: "Milk", price: 3.00),
        GroceryItem(name: "Bread", price: 2.00)
    ]
    
    func addItem(_ item: GroceryItem) {
        groceryList.append(item)
        spent += item.price
    }
    
    func completePurchase() {
        let total = groceryList.reduce(0.0) { $0 + $1.price }
        
        let purchase = Purchase(
            items: groceryList,
            total: total,
            date: Date(),
            paymentMethod: selectedPayment
        )
        
        purchases.append(purchase)
        groceryList.removeAll()
    }
    
    func budgetRemaining() -> Double {
        return max(budget - spent, 0.0)
    }
    
    func isNearLimit() -> Bool {
        return spent >= budget * 0.8
    }
    
    func monthlySpending() -> Double {
        let calendar = Calendar.current
        let now = Date()
        
        return purchases
            .filter { calendar.isDate($0.date, equalTo: now, toGranularity: .month) }
            .reduce(0.0) { $0 + $1.total }
    }
}

// MARK: - Main View
struct ContentView: View {
    
    @StateObject var vm = BudgetViewModel()
    
    var body: some View {
        TabView {
            
            // Dashboard
            ZStack {
                Color.black.ignoresSafeArea()
                
                VStack(spacing: 20) {
                    
                    Text("My Buggy")
                        .font(.largeTitle)
                        .bold()
                        .foregroundColor(.white)
                        .padding(.bottom)
                    
                    Text("Budget: $\(vm.budget, specifier: "%.2f")")
                        .foregroundColor(.white)
                    Text("Spent: $\(vm.spent, specifier: "%.2f")")
                        .foregroundColor(.white)
                    Text("Remaining: $\(vm.budgetRemaining(), specifier: "%.2f")")
                        .foregroundColor(.green)
                    
                    if vm.isNearLimit() {
                        Text("Limit Reached")
                            .foregroundColor(.red)
                    }
                }
                .padding()
            }
            .tabItem {
                Label("Dashboard", systemImage: "chart.pie")
            }
            
            
            // Grocery List
            ZStack {
                Color.black.ignoresSafeArea()
                
                VStack {
                    
                    Text("Quick Add")
                        .font(.headline)
                        .foregroundColor(.white)
                    
                    ForEach(vm.defaultItems) { item in
                        Button(action: {
                            vm.addItem(item)
                        }) {
                            HStack {
                                Image(systemName: "cart.fill")
                                    .font(.largeTitle)
                                    .foregroundColor(.white)
                                Text(item.name)
                                    .foregroundColor(.white)
                                Spacer()
                                Text("$\(item.price, specifier: "%.2f")")
                                    .foregroundColor(.white)
                            }
                            .padding()
                            .background(Color.white.opacity(0.3))
                            .cornerRadius(10)
                        }
                    }
                    
                    Divider().background(Color.white)
                    
                    List(vm.groceryList) { item in
                        HStack {
                            Text(item.name)
                                .foregroundColor(.white)
                            Spacer()
                            Text("$\(item.price, specifier: "%.2f")")
                                .foregroundColor(.white)
                        }
                        .listRowBackground(Color.gray.opacity(0.4))
                    }
                    .scrollContentBackground(.hidden)
                    
                    Text("Total: $\(vm.groceryList.reduce(0.0) { $0 + $1.price }, specifier: "%.2f")")
                        .font(.headline)
                        .foregroundColor(.green)
                        .padding()

                    Text("Select Payment Method")
                        .foregroundColor(.white)
                        .font(.headline)

                    VStack(spacing: 12) {
                        ForEach(PaymentMethod.allCases) { method in
                            Button {
                                vm.selectedPayment = method
                            } label: {
                                PaymentCardView(
                                    method: method,
                                    isSelected: vm.selectedPayment == method
                                )
                            }
                        }
                    }
                    .padding(.vertical)
                    
                    Button("Checkout") {
                        vm.completePurchase()
                    }
                    .padding()
                }
                .padding()
            }
            .tabItem {
                Label("Shop", systemImage: "cart.fill")
            }
            
            
            // History
            ZStack {
                Color.black.ignoresSafeArea()
                
                VStack {
                    
                    VStack {
                        Text("This Month")
                            .font(.headline)
                            .foregroundColor(.white)
                        
                        Text("$\(vm.monthlySpending(), specifier: "%.2f")")
                            .font(.largeTitle)
                            .bold()
                            .foregroundColor(.green)
                    }
                    .padding()
                    
                    List(vm.purchases) { purchase in
                        VStack(alignment: .leading) {
                            
                            Text("Items: \(purchase.items.map { $0.name }.joined(separator: ", "))")
                                .foregroundColor(.white)
                            
                            Text("Total: $\(purchase.total, specifier: "%.2f")")
                                .foregroundColor(.green)
                            
                            Text("Payment: \(purchase.paymentMethod.rawValue)")
                                .foregroundColor(.white)
                            
                            Text("Date: \(purchase.date.formatted())")
                                .font(.caption)
                                .foregroundColor(.gray)
                        }
                        .listRowBackground(Color.gray.opacity(0.3))
                    }
                    .scrollContentBackground(.hidden)
                }
            }
            .tabItem {
                Label("History", systemImage: "clock")
            }
        }
    }
}

